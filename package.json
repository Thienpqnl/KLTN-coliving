{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:gateway": "node --watch services/api-gateway/server.cjs",
    "start:gateway": "node services/api-gateway/server.cjs",
    "test:gateway": "node --test services/api-gateway/*.test.cjs services/shared/observability.test.cjs",
    "kong:validate": "docker compose -f docker-compose.microservices.yml exec -T kong kong config parse /kong/declarative/kong.yml",
    "dev:property": "node --watch services/property-service/server.cjs",
    "predev:property": "prisma generate --schema services/property-service/prisma/schema.prisma",
    "dev:identity": "node --watch services/identity-service/server.cjs",
    "predev:identity": "prisma generate --schema services/identity-service/prisma/schema.prisma",
    "dev:rental": "node --watch services/rental-service/server.cjs",
    "predev:rental": "prisma generate --schema services/rental-service/prisma/schema.prisma",
    "dev:community": "node --watch services/community-service/server.cjs",
    "predev:community": "prisma generate --schema services/community-service/prisma/schema.prisma",
    "dev:preference": "node --watch services/preference-service/server.cjs",
    "predev:preference": "prisma generate --schema services/preference-service/prisma/schema.prisma",
    "start:property": "node services/property-service/server.cjs",
    "prestart:property": "prisma generate --schema services/property-service/prisma/schema.prisma",
    "start:identity": "node services/identity-service/server.cjs",
    "prestart:identity": "prisma generate --schema services/identity-service/prisma/schema.prisma",
    "start:rental": "node services/rental-service/server.cjs",
    "prestart:rental": "prisma generate --schema services/rental-service/prisma/schema.prisma",
    "start:community": "node services/community-service/server.cjs",
    "prestart:community": "prisma generate --schema services/community-service/prisma/schema.prisma",
    "start:preference": "node services/preference-service/server.cjs",
    "prestart:preference": "prisma generate --schema services/preference-service/prisma/schema.prisma",
    "test:property": "node --test services/property-service/*.test.cjs",
    "test:identity": "node --test services/identity-service/*.test.cjs",
    "test:rental": "node --test services/rental-service/*.test.cjs",
    "test:community": "node --test services/community-service/*.test.cjs",
    "test:services": "node --test services/*/*.test.cjs",
    "pretest:services": "npm run prisma:generate:services",
    "test:schema-split": "node --test scripts/migrate-to-service-schemas.test.cjs",
    "services:up": "docker compose -f docker-compose.microservices.yml up --build",
    "services:down": "docker compose -f docker-compose.microservices.yml down",
    "prisma:generate:services": "prisma generate --schema services/identity-service/prisma/schema.prisma && prisma generate --schema services/property-service/prisma/schema.prisma && prisma generate --schema services/rental-service/prisma/schema.prisma && prisma generate --schema services/community-service/prisma/schema.prisma && prisma generate --schema services/preference-service/prisma/schema.prisma",
    "prisma:validate:services": "prisma validate --schema services/identity-service/prisma/schema.prisma && prisma validate --schema services/property-service/prisma/schema.prisma && prisma validate --schema services/rental-service/prisma/schema.prisma && prisma validate --schema services/community-service/prisma/schema.prisma && prisma validate --schema services/preference-service/prisma/schema.prisma",
    "schema:split:prepare": "node scripts/migrate-to-service-schemas.cjs",
    "schema:split:verify": "node scripts/migrate-to-service-schemas.cjs --verify-only",
    "ai:projections:bootstrap": "docker compose -f docker-compose.microservices.yml run --rm ai-service python scripts/bootstrap_projections.py",
    "ai:projections:reconcile": "docker compose -f docker-compose.microservices.yml run --rm ai-service python scripts/reconcile_projections.py",
    "ai:projections:test-reconcile": "docker compose -f docker-compose.microservices.yml run --rm ai-service python scripts/test_reconciliation.py",
    "ai:database:configure-role": "node scripts/configure-ai-database-role.cjs",
    "ai:projections:test-event": "docker compose -f docker-compose.microservices.yml run --rm ai-service python scripts/test_projection_event.py",
    "events:dlq:replay": "node scripts/replay-dlq.cjs",
    "events:dlq:test": "docker compose -f docker-compose.microservices.yml run --rm ai-service python scripts/test_dlq.py",
    "events:dlq:status": "node scripts/dlq-status.cjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:admin": "node scripts/seed-admin.mjs",
    "import:rooms": "ts-node scripts/import-rooms.ts",
    "import:rooms:cjs": "node scripts/import-rooms-cjs.js"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "2.1.1",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-avatar": "^1.1.11",
    "amqplib": "^0.10.9",
    "bcrypt": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "firebase-admin": "^13.10.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "mapbox-gl": "^3.24.0",
    "next": "^16.2.3",
    "next-auth": "^4.24.14",
    "oklch": "^0.0.2",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/google.maps": "^3.65.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
