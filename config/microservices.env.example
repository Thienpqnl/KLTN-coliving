# Next.js BFF: leave a URL empty to keep using the local implementation.
PROPERTY_SERVICE_URL=http://localhost:4002
AI_SERVICE_URL=http://localhost:8000

# Reserved for the next extraction phases.
IDENTITY_SERVICE_URL=http://localhost:4001
RENTAL_SERVICE_URL=http://localhost:4003
COMMUNITY_SERVICE_URL=http://localhost:4004
PREFERENCE_SERVICE_URL=http://localhost:4005

# Schema-per-service URLs in the same Supabase PostgreSQL project. Keep
# DATABASE_URL pointed at public until the schema split verification passes.
IDENTITY_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=identity
PROPERTY_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=property
RENTAL_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=rental
COMMUNITY_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=community
PREFERENCE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?schema=preference

# Direct PostgreSQL connection used only by the one-time schema copy tool.
# Prefer port 5432 instead of a transaction-pooler URL.
SCHEMA_SPLIT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Enable only after custom schemas are exposed to the Supabase Data API.
AI_DATABASE_URL=postgresql://ai_reader.PROJECT_REF:PASSWORD@POOLER_HOST:5432/postgres
USE_SERVICE_SCHEMAS=true
AI_USE_PROJECTIONS=true

# BFF waits briefly, then falls back to the existing implementation.
MICROSERVICE_TIMEOUT_MS=3000

# Default is strict. Set to false only for local debugging with service fallbacks.
MICROSERVICE_STRICT=true

# Generate a long random value and use the same secret in the BFF and services.
INTERNAL_SERVICE_TOKEN=replace-with-at-least-32-random-characters

# Event transport for Transactional Outbox
RABBITMQ_URL=amqp://coliving:coliving-dev@localhost:5672
RABBITMQ_EXCHANGE=coliving.events
OUTBOX_POLL_INTERVAL_MS=1000
