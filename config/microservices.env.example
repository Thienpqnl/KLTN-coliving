# Next.js BFF: leave a URL empty to keep using the local implementation.
PROPERTY_SERVICE_URL=http://localhost:4002
AI_SERVICE_URL=http://localhost:8000

# Reserved for the next extraction phases.
IDENTITY_SERVICE_URL=http://localhost:4001
RENTAL_SERVICE_URL=http://localhost:4003
COMMUNITY_SERVICE_URL=http://localhost:4004
PREFERENCE_SERVICE_URL=http://localhost:4005

# BFF waits briefly, then falls back to the existing implementation.
MICROSERVICE_TIMEOUT_MS=3000

# Default is strict. Set to false only for local debugging with service fallbacks.
MICROSERVICE_STRICT=true

# Generate a long random value and use the same secret in the BFF and services.
INTERNAL_SERVICE_TOKEN=replace-with-at-least-32-random-characters
