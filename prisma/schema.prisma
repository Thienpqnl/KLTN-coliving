generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String                   @id @default(uuid())
  email            String                   @unique
  password         String
  fullName         String
  createdAt        DateTime                 @default(now())
  address          String?
  avatarUrl        String?
  birthDate        DateTime?
  gender           String?
  name             String
  phone            String?
  role             Role                     @default(CUSTOMER)
  status           UserStatus               @default(ACTIVE)
  updatedAt        DateTime                 @updatedAt
  adminActions     AdminLog[]               @relation("AdminAction")
  affectedLogs     AdminLog[]               @relation("AffectedUser")
  bookings         Booking[]
  invoices         Invoice[]
  reviews          Review[]
  rooms            Room[]
  preference       user_preferences?
  lifestyleProfile user_lifestyle_profiles?
  favorites        FavoriteRoom[]
  occupancies      Occupancy[]
  contracts        Contract[]
  roomInteractions RoomInteraction[]

  @@map("User")
}

model user_preferences {
  id                        String   @id @default(uuid())
  userId                    String   @unique
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetMinVnd              BigInt?
  budgetMaxVnd              BigInt?
  preferredDistrict         String?
  lifestyleArchetype        String?
  priorityCleanliness       Int?     @default(3)
  prioritySocialEnvironment Int?     @default(3)
  acceptSmokingRoommates    Boolean? @default(false)
  acceptPets                Boolean? @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@index([userId])
  @@map("user_preferences")
}

model user_lifestyle_profiles {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  smoking      SmokingType?
  pets         Boolean?
  petTolerance Boolean?

  sleepTime  SleepTime?
  wakeupTime Int?

  cleanliness    Int?
  noiseTolerance Int?
  sociability    Int?
  privacyLevel   Int?

  guestsFrequency GuestFrequency?

  cookingFrequency Int?

  budget BigInt?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_lifestyle_profiles")
}

enum SmokingType {
  NO
  OCCASIONALLY
  YES
}

enum SleepTime {
  BEFORE_10PM
  BETWEEN_10_12
  AFTER_12
}

enum GuestFrequency {
  NEVER
  SOMETIMES
  OFTEN
}

model Room {
  id                  String            @id @default(uuid())
  roomId              String?
  title               String
  description         String
  address             String
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  ownerId             String?
  status              RoomStatus        @default(AVAILABLE)
  areaText            String?
  areaValue           Decimal?          @db.Decimal(10, 2)
  city                String?
  district            String?
  districtId          String?
  priceText           String?
  priceValue          BigInt?
  sourceUrl           String?
  posted_date         String?
  expired_date        String?
  bookings            Booking[]
  favoritedBy         FavoriteRoom[]
  reviews             Review[]
  owner               User?             @relation(fields: [ownerId], references: [id])
  amenities           RoomAmenity[]
  images              RoomImage[]
  occupancies         Occupancy[]
  contracts           Contract[]
  cleanlinessRequired String?
  noiseTolerance      String?
  guestPolicy         String?
  preferredSleepHabit String?
  preferredOccupation String?
  curfewPolicy        String?
  maxOccupants        Int?              @default(1)
  currentOccupants    Int?              @default(0)
  preferredGender     String?
  allowSmoking        Boolean?          @default(false)
  allowPets           Boolean?          @default(false)
  roomInteractions    RoomInteraction[]

  @@map("Room")
}

model Amenity {
  id    String        @id @default(uuid())
  name  String        @unique
  rooms RoomAmenity[]
}

model RoomAmenity {
  id        String  @id @default(uuid())
  roomId    String
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id])
  room      Room    @relation(fields: [roomId], references: [id])

  @@unique([roomId, amenityId])
}

model RoomImage {
  id        String   @id @default(uuid())
  roomId    String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model FavoriteRoom {
  id        String   @id @default(uuid())
  userId    String
  roomId    String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@index([userId])
  @@index([roomId])
}

model Booking {
  id        String        @id @default(uuid())
  userId    String
  roomId    String
  startDate DateTime
  endDate   DateTime
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  room      Room          @relation(fields: [roomId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
  invoice   Invoice?
}

model Invoice {
  id          String        @id @default(uuid())
  userId      String
  bookingId   String        @unique
  totalAmount Float
  status      InvoiceStatus @default(UNSIGNED)
  signature   String?
  hash        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     Booking       @relation(fields: [bookingId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  payment     Payment?
}

model Payment {
  id        String        @id @default(uuid())
  invoiceId String        @unique
  amount    Float
  method    String
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  invoice   Invoice       @relation(fields: [invoiceId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  roomId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model AdminLog {
  id           String   @id @default(uuid())
  adminId      String
  targetUserId String?
  action       String
  targetId     String?
  targetType   String
  oldValue     String?
  newValue     String?
  description  String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  admin        User     @relation("AdminAction", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser   User?    @relation("AffectedUser", fields: [targetUserId], references: [id], onDelete: Cascade)
}

enum Role {
  CUSTOMER
  SERVER
  DELIVER
  ADMIN
  HOST
}

enum UserStatus {
  ACTIVE
  LOCKED
  DELETED
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  PENDING
  HIDDEN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum InvoiceStatus {
  UNSIGNED
  SIGNED
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

model Contract {
  id String @id @default(uuid())

  roomId   String
  renterId String

  startDate DateTime
  endDate   DateTime

  monthlyRent   Float
  depositAmount Float

  renewalCount Int @default(0)

  status ContractStatus @default(ACTIVE)

  terminatedAt      DateTime?
  terminationReason String?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  room   Room @relation(fields: [roomId], references: [id])
  renter User @relation(fields: [renterId], references: [id])
}

model Occupancy {
  id                String    @id @default(uuid())
  roomId            String
  userId            String
  joinedAt          DateTime  @default(now()) @db.Timestamp(6)
  status            String    @default("ACTIVE")
  terminatedAt      DateTime?
  terminationReason String?
  notes             String?

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roomId, userId], name: "Occupancy_room_user_unique")
  @@index([roomId], map: "Occupancy_roomId_idx")
  @@index([userId], map: "Occupancy_userId_idx")
  @@index([status], map: "Occupancy_status_idx")
  @@index([terminatedAt], map: "Occupancy_terminatedAt_idx")
  @@map("occupancy")
}

enum InteractionType {
  VIEW // Người dùng bấm vào xem chi tiết phòng (Trọng số: 1)
  CLICK // Người dùng click vào ảnh/tiện ích (Trọng số: 2)
  FAVORITE // Người dùng thêm vào danh sách yêu thích (Trọng số: 3)
  BOOKING_REQ // Người dùng gửi yêu cầu đặt phòng (Trọng số: 4)
  CONTRACT // Người dùng đã ký hợp đồng thành công (Trọng số: 5)
}

model RoomInteraction {
  id               String          @id @default(uuid())
  userId           String
  roomId           String
  interactionType  InteractionType
  interactionValue Float           @default(1.0) // Điểm số hóa để nạp trực tiếp vào AI pipeline
  durationSeconds  Int?            @default(0) // Thời gian ở lại trang (áp dụng cho VIEW)
  createdAt        DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roomId])
  @@index([interactionType])
  @@map("room_interactions")
}
