generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                   @id @default(uuid())
  email                     String                   @unique
  password                  String
  fullName                  String
  createdAt                 DateTime                 @default(now())
  address                   String?
  avatarUrl                 String?
  birthDate                 DateTime?
  gender                    String?
  name                      String
  phone                     String?
  role                      Role                     @default(CUSTOMER)
  status                    UserStatus               @default(ACTIVE)
  updatedAt                 DateTime                 @updatedAt
  latitude                  Float?
  longitude                 Float?
  adminActions              AdminLog[]               @relation("AdminAction")
  affectedLogs              AdminLog[]               @relation("AffectedUser")
  bookings                  Booking[]
  hostedContracts           Contract[]               @relation("ContractHost")
  rentedContracts           Contract[]               @relation("ContractRenter")
  favorites                 FavoriteRoom[]
  invoices                  Invoice[]
  reviews                   Review[]
  rooms                     Room[]
  RoomInteraction           RoomInteraction[]
  occupancies               Occupancy[]
  lifestyleProfile          user_lifestyle_profiles?
  preference                user_preferences?
  reviewedRoomVerifications RoomVerification[]       @relation("RoomVerificationReviewer")

  @@map("User")
}

model user_preferences {
  id                        String   @id @default(uuid())
  userId                    String   @unique
  budgetMinVnd              BigInt?
  budgetMaxVnd              BigInt?
  preferredDistrict         String?
  lifestyleArchetype        String?
  priorityCleanliness       Int?     @default(3)
  prioritySocialEnvironment Int?     @default(3)
  acceptSmokingRoommates    Boolean? @default(false)
  acceptPets                Boolean? @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_preferences")
}

model user_lifestyle_profiles {
  id               String          @id @default(uuid())
  userId           String          @unique
  smoking          SmokingType?
  pets             Boolean?
  petTolerance     Boolean?
  sleepTime        SleepTime?
  wakeupTime       Int?
  cleanliness      Int?
  noiseTolerance   Int?
  sociability      Int?
  privacyLevel     Int?
  guestsFrequency  GuestFrequency?
  cookingFrequency Int?
  budget           BigInt?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_lifestyle_profiles")
}

model Room {
  id                  String            @id @default(uuid())
  title               String
  description         String
  address             String
  city                String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  allowPets           Boolean?          @default(false)
  allowSmoking        Boolean?          @default(false)
  areaText            String?
  areaValue           Decimal?          @db.Decimal(10, 2)
  cleanlinessRequired String?
  curfewPolicy        String?
  currentOccupants    Int?              @default(0)
  district            String?
  districtId          String?
  expired_date        String?
  guestPolicy         String?
  maxOccupants        Int?              @default(1)
  noiseTolerance      String?
  ownerId             String?
  posted_date         String?
  preferredGender     String?
  preferredOccupation String?
  preferredSleepHabit String?
  priceText           String?
  priceValue          BigInt?
  roomId              String?
  sourceUrl           String?
  status              RoomStatus        @default(DRAFT)
  latitude            Float?
  longitude           Float?
  bookings            Booking[]
  contracts           Contract[]
  favoritedBy         FavoriteRoom[]
  reviews             Review[]
  owner               User?             @relation(fields: [ownerId], references: [id])
  amenities           RoomAmenity[]
  images              RoomImage[]
  RoomInteraction     RoomInteraction[]
  occupancies         Occupancy[]
  verification        RoomVerification?

  @@map("Room")
}

model Amenity {
  id    String        @id @default(uuid())
  name  String        @unique
  rooms RoomAmenity[]
}

model RoomAmenity {
  id        String  @id @default(uuid())
  roomId    String
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id])
  room      Room    @relation(fields: [roomId], references: [id])

  @@unique([roomId, amenityId])
}

model RoomImage {
  id        String   @id @default(uuid())
  roomId    String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model FavoriteRoom {
  id        String   @id @default(uuid())
  userId    String
  roomId    String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@index([userId])
  @@index([roomId])
}

model Booking {
  id        String        @id @default(uuid())
  userId    String
  roomId    String
  startDate DateTime
  endDate   DateTime
  status    BookingStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  room      Room          @relation(fields: [roomId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
  contract  Contract[]
  invoice   Invoice?
}

model Invoice {
  id          String        @id @default(uuid())
  userId      String
  bookingId   String        @unique
  totalAmount Float
  status      InvoiceStatus @default(UNSIGNED)
  signature   String?
  hash        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     Booking       @relation(fields: [bookingId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  payment     Payment?
}

model Payment {
  id        String        @id @default(uuid())
  invoiceId String        @unique
  amount    Float
  method    String
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  invoice   Invoice       @relation(fields: [invoiceId], references: [id])
}

model Review {
  id        String       @id @default(uuid())
  userId    String
  roomId    String
  rating    Int
  comment   String?
  status    ReviewStatus @default(VISIBLE)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  room      Room         @relation(fields: [roomId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([status])
}

model RoomVerification {
  id              String                     @id @default(uuid())
  roomId          String                     @unique
  reviewerId      String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  revisionReason  String?
  rejectionReason String?
  adminNote       String?
  identityPassed  Boolean                    @default(false)
  ownershipPassed Boolean                    @default(false)
  addressPassed   Boolean                    @default(false)
  imagesPassed    Boolean                    @default(false)
  detailsPassed   Boolean                    @default(false)
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  room            Room                       @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reviewer        User?                      @relation("RoomVerificationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  documents       RoomVerificationDocument[]

  @@index([reviewerId])
  @@index([submittedAt])
}

model RoomVerificationDocument {
  id             String                     @id @default(uuid())
  verificationId String
  type           VerificationDocumentType
  fileUrl        String
  status         VerificationDocumentStatus @default(PENDING)
  note           String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  verification   RoomVerification           @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([type])
}

model AdminLog {
  id           String   @id @default(uuid())
  adminId      String
  targetUserId String?
  action       String
  targetId     String?
  targetType   String
  oldValue     String?
  newValue     String?
  description  String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  admin        User     @relation("AdminAction", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser   User?    @relation("AffectedUser", fields: [targetUserId], references: [id], onDelete: Cascade)
}

model Contract {
  id       String @id @default(uuid())
  roomId   String
  renterId String

  startDate DateTime
  endDate   DateTime

  monthlyRent       Float
  depositAmount     Float
  renewalCount      Int            @default(0)
  status            ContractStatus @default(ACTIVE)
  terminatedAt      DateTime?
  terminationReason String?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  hostId            String
  bookingId         String?
  booking           Booking?       @relation(fields: [bookingId], references: [id])
  host              User?          @relation("ContractHost", fields: [hostId], references: [id])
  renter            User           @relation("ContractRenter", fields: [renterId], references: [id])
  room              Room           @relation(fields: [roomId], references: [id])

  @@index([hostId])
}

model Occupancy {
  id                String    @id @default(uuid())
  roomId            String
  userId            String
  joinedAt          DateTime  @default(now()) @db.Timestamp(6)
  status            String    @default("ACTIVE")
  terminatedAt      DateTime?
  terminationReason String?
  notes             String?
  room              Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId], name: "Occupancy_room_user_unique")
  @@index([roomId], map: "Occupancy_roomId_idx")
  @@index([userId], map: "Occupancy_userId_idx")
  @@index([status], map: "Occupancy_status_idx")
  @@index([terminatedAt], map: "Occupancy_terminatedAt_idx")
  @@map("occupancy")
}

model RoomInteraction {
  id               String          @id
  userId           String
  roomId           String
  interactionType  InteractionType
  interactionValue Float           @default(1.0)
  durationSeconds  Int?            @default(0)
  createdAt        DateTime        @default(now())
  Room             Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  User             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
}

enum SmokingType {
  NO
  OCCASIONALLY
  YES
}

enum SleepTime {
  BEFORE_10PM
  BETWEEN_10_12
  AFTER_12
}

enum GuestFrequency {
  NEVER
  SOMETIMES
  OFTEN
}

enum Role {
  CUSTOMER
  SERVER
  DELIVER
  ADMIN
  HOST
}

enum UserStatus {
  ACTIVE
  LOCKED
  DELETED
}

enum RoomStatus {
  DRAFT
  AVAILABLE
  OCCUPIED
  PENDING
  NEEDS_REVISION
  REJECTED
  HIDDEN
}

enum VerificationDocumentType {
  IDENTITY
  OWNERSHIP
  ADDRESS
  ROOM_PROOF
  OTHER
}

enum VerificationDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum InvoiceStatus {
  UNSIGNED
  SIGNED
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  TERMINATED
}

enum ReviewStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum InteractionType {
  VIEW
  CLICK
  FAVORITE
  BOOKING_REQ
  CONTRACT
}
