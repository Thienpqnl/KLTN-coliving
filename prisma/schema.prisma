generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                        String                   @id @default(uuid())
  email                     String                   @unique
  password                  String
  fullName                  String
  createdAt                 DateTime                 @default(now())
  address                   String?
  avatarUrl                 String?
  birthDate                 DateTime?
  gender                    String?
  name                      String
  phone                     String?
  phoneVerified             Boolean                  @default(false)
  phoneVerifiedAt           DateTime?
  role                      Role                     @default(CUSTOMER)
  status                    UserStatus               @default(ACTIVE)
  updatedAt                 DateTime                 @updatedAt
  latitude                  Float?
  longitude                 Float?
  adminActions              AdminLog[]               @relation("AdminAction")
  affectedLogs              AdminLog[]               @relation("AffectedUser")
  bookings                  Booking[]
  hostedContracts           Contract[]               @relation("ContractHost")
  rentedContracts           Contract[]               @relation("ContractRenter")
  contractEvents            ContractEvent[]
  favorites                 FavoriteRoom[]
  invoices                  Invoice[]
  reviews                   Review[]
  rooms                     Room[]
  RoomInteraction           RoomInteraction[]
  occupancies               Occupancy[]
  lifestyleProfile          user_lifestyle_profiles?
  preference                user_preferences?
  reviewedRoomVerifications RoomVerification[]       @relation("RoomVerificationReviewer")
  managedRoomVerifications  RoomVerification[]       @relation("RoomVerificationManager")
  communityManagerAreas     CommunityManagerArea[]
  verificationChecks        VerificationCheck[]      @relation("VerificationCheckReviewer")
  phoneOtps                 PhoneOtp[]
  deviceTokens              UserDeviceToken[]
  resourceBookings          ResourceBooking[]
  createdActivities         SharedSpaceActivity[]    @relation("ActivityCreator")
  assignedActivities        SharedSpaceActivity[]    @relation("ActivityAssignee")

  @@map("User")
}

model UserDeviceToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  deviceType String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model user_preferences {
  id                        String   @id @default(uuid())
  userId                    String   @unique
  budgetMinVnd              BigInt?
  budgetMaxVnd              BigInt?
  preferredDistrict         String?
  lifestyleArchetype        String?
  priorityCleanliness       Int?     @default(3)
  prioritySocialEnvironment Int?     @default(3)
  acceptSmokingRoommates    Boolean? @default(false)
  acceptPets                Boolean? @default(false)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_preferences")
}

model user_lifestyle_profiles {
  id               String          @id @default(uuid())
  userId           String          @unique
  smoking          SmokingType?
  pets             Boolean?
  petTolerance     Boolean?
  sleepTime        SleepTime?
  wakeupTime       Int?
  cleanliness      Int?
  noiseTolerance   Int?
  sociability      Int?
  privacyLevel     Int?
  guestsFrequency  GuestFrequency?
  cookingFrequency Int?
  budget           BigInt?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_lifestyle_profiles")
}

model Room {
  id                    String                @id @default(uuid())
  title                 String
  description           String
  address               String
  city                  String?
  provinceCode          String?
  ward                  String?
  wardCode              String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  allowPets             Boolean?              @default(false)
  allowSmoking          Boolean?              @default(false)
  areaText              String?
  areaValue             Decimal?              @db.Decimal(10, 2)
  cleanlinessRequired   String?
  curfewPolicy          String?
  currentOccupants      Int?                  @default(0)
  district              String?
  districtId            String?
  expired_date          String?
  guestPolicy           String?
  maxOccupants          Int?                  @default(1)
  noiseTolerance        String?
  ownerId               String?
  posted_date           String?
  preferredGender       String?
  preferredOccupation   String?
  preferredSleepHabit   String?
  priceText             String?
  priceValue            BigInt?
  roomId                String?
  sourceUrl             String?
  status                RoomStatus            @default(DRAFT)
  latitude              Float?
  longitude             Float?
  bookings              Booking[]
  contracts             Contract[]
  favoritedBy           FavoriteRoom[]
  reviews               Review[]
  owner                 User?                 @relation(fields: [ownerId], references: [id])
  amenities             RoomAmenity[]
  images                RoomImage[]
  RoomInteraction       RoomInteraction[]
  occupancies           Occupancy[]
  verification          RoomVerification?
  sharedResources       SharedResource[]
  sharedSpaceActivities SharedSpaceActivity[]

  @@map("Room")
}

model Amenity {
  id    String        @id @default(uuid())
  name  String        @unique
  rooms RoomAmenity[]
}

model RoomAmenity {
  id        String  @id @default(uuid())
  roomId    String
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id])
  room      Room    @relation(fields: [roomId], references: [id])

  @@unique([roomId, amenityId])
}

model RoomImage {
  id        String   @id @default(uuid())
  roomId    String
  url       String
  alt       String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@index([roomId])
}

model FavoriteRoom {
  id        String   @id @default(uuid())
  userId    String
  roomId    String
  createdAt DateTime @default(now())
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@index([userId])
  @@index([roomId])
}

model Booking {
  id                 String        @id @default(uuid())
  userId             String
  roomId             String
  startDate          DateTime
  endDate            DateTime
  status             BookingStatus @default(PENDING)
  cancelledAt        DateTime?
  cancelledById      String?
  cancellationActor  String?
  cancellationReason String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  room               Room          @relation(fields: [roomId], references: [id])
  user               User          @relation(fields: [userId], references: [id])
  contract           Contract?
  invoice            Invoice?

  @@index([cancelledById])
}

model Invoice {
  id          String        @id @default(uuid())
  userId      String
  bookingId   String        @unique
  totalAmount Float
  status      InvoiceStatus @default(UNSIGNED)
  signature   String?
  hash        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  booking     Booking       @relation(fields: [bookingId], references: [id])
  user        User          @relation(fields: [userId], references: [id])
  payment     Payment?
}

model Payment {
  id        String        @id @default(uuid())
  invoiceId String        @unique
  amount    Float
  method    String
  status    PaymentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  invoice   Invoice       @relation(fields: [invoiceId], references: [id])
}

model Review {
  id        String       @id @default(uuid())
  userId    String
  roomId    String
  rating    Int
  comment   String?
  createdAt DateTime     @default(now())
  status    ReviewStatus @default(VISIBLE)
  updatedAt DateTime     @updatedAt
  room      Room         @relation(fields: [roomId], references: [id])
  user      User         @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([status])
}

model RoomVerification {
  id                           String                         @id @default(uuid())
  roomId                       String                         @unique
  reviewerId                   String?
  assignedManagerId            String?
  submittedAt                  DateTime?
  managerAssignedAt            DateTime?
  managerReviewedAt            DateTime?
  reviewedAt                   DateTime?
  revisionReason               String?
  rejectionReason              String?
  adminNote                    String?
  managerNote                  String?
  inspectionDate               DateTime?
  inspectionImages             Json?
  managerRecommendation        CommunityManagerRecommendation @default(PENDING)
  identityPassed               Boolean                        @default(false)
  ownershipPassed              Boolean                        @default(false)
  addressPassed                Boolean                        @default(false)
  imagesPassed                 Boolean                        @default(false)
  detailsPassed                Boolean                        @default(false)
  facilityPassed               Boolean                        @default(false)
  safetyPassed                 Boolean                        @default(false)
  legalOccupancyPassed         Boolean                        @default(false)
  informationAccurateConfirmed Boolean                        @default(false)
  legalResponsibilityAccepted  Boolean                        @default(false)
  verificationConsentAccepted  Boolean                        @default(false)
  declarationAcceptedAt        DateTime?
  declarationVersion           String?
  declarationIpAddress         String?
  declarationUserAgent         String?
  createdAt                    DateTime                       @default(now())
  updatedAt                    DateTime                       @updatedAt
  room                         Room                           @relation(fields: [roomId], references: [id], onDelete: Cascade)
  reviewer                     User?                          @relation("RoomVerificationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  assignedManager              User?                          @relation("RoomVerificationManager", fields: [assignedManagerId], references: [id], onDelete: SetNull)
  documents                    RoomVerificationDocument[]
  checks                       VerificationCheck[]

  @@index([reviewerId])
  @@index([assignedManagerId])
  @@index([managerRecommendation])
  @@index([submittedAt])
}

model VerificationCheck {
  id             String                  @id @default(uuid())
  verificationId String
  type           VerificationCheckType
  status         VerificationCheckStatus @default(PENDING)
  sourceValue    String?
  targetValue    String?
  note           String?
  checkedById    String?
  checkedAt      DateTime?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  verification   RoomVerification        @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  checkedBy      User?                   @relation("VerificationCheckReviewer", fields: [checkedById], references: [id], onDelete: SetNull)

  @@unique([verificationId, type])
  @@index([verificationId])
  @@index([type])
  @@index([status])
  @@index([checkedById])
}

model PhoneOtp {
  id           String    @id @default(uuid())
  userId       String
  phone        String
  codeHash     String
  expiresAt    DateTime
  verifiedAt   DateTime?
  attemptCount Int       @default(0)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([phone])
  @@index([expiresAt])
}

model CommunityManagerArea {
  id           String         @id @default(uuid())
  managerId    String
  region       ServiceRegion?
  city         String?
  provinceCode String?
  ward         String?
  wardCode     String?
  district     String?
  districtId   String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  manager      User           @relation(fields: [managerId], references: [id], onDelete: Cascade)

  @@unique([managerId, region, city, provinceCode, ward, wardCode, district, districtId], name: "CommunityManagerArea_unique_scope")
  @@index([managerId])
  @@index([region])
  @@index([city])
  @@index([provinceCode])
  @@index([ward])
  @@index([wardCode])
  @@index([district])
  @@index([districtId])
}

model RoomVerificationDocument {
  id             String                     @id @default(uuid())
  verificationId String
  type           VerificationDocumentType
  fileUrl        String
  status         VerificationDocumentStatus @default(PENDING)
  note           String?
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  verification   RoomVerification           @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([type])
}

model AdminLog {
  id           String   @id @default(uuid())
  adminId      String
  targetUserId String?
  action       String
  targetId     String?
  targetType   String
  oldValue     String?
  newValue     String?
  description  String?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  admin        User     @relation("AdminAction", fields: [adminId], references: [id], onDelete: Cascade)
  targetUser   User?    @relation("AffectedUser", fields: [targetUserId], references: [id], onDelete: Cascade)
}

model Contract {
  id                        String                @id @default(uuid())
  roomId                    String
  renterId                  String
  startDate                 DateTime
  endDate                   DateTime
  monthlyRent               Float
  depositAmount             Float
  renewalCount              Int                   @default(0)
  status                    ContractStatus        @default(DRAFT)
  terminatedAt              DateTime?
  terminationReason         String?
  notes                     String?
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  hostId                    String
  bookingId                 String?               @unique
  contractNumber            String                @unique
  depositStatus             ContractDepositStatus @default(PENDING)
  depositPaidAt             DateTime?
  depositReference          String?
  paymentDueDay             Int                   @default(5)
  paymentMethod             String?
  electricityRate           Float?
  waterRate                 Float?
  utilitiesNotes            String?
  noticeDays                Int                   @default(30)
  depositReturnDays         Int                   @default(7)
  houseRules                String?
  inventory                 Json?
  contentSnapshot           Json
  contentHash               String
  termsVersion              String                @default("VN-HOUSING-2023-v1")
  hostSignedAt              DateTime?
  hostSignatureName         String?
  hostSignatureIp           String?
  hostSignatureUserAgent    String?
  renterSignedAt            DateTime?
  renterSignatureName       String?
  renterSignatureIp         String?
  renterSignatureUserAgent  String?
  hostHandoverConfirmedAt   DateTime?
  renterHandoverConfirmedAt DateTime?
  handoverNotes             String?
  activatedAt               DateTime?
  booking                   Booking?              @relation(fields: [bookingId], references: [id])
  host                      User                  @relation("ContractHost", fields: [hostId], references: [id])
  renter                    User                  @relation("ContractRenter", fields: [renterId], references: [id])
  room                      Room                  @relation(fields: [roomId], references: [id])
  events                    ContractEvent[]
  utilityBills              UtilityBill[]

  @@index([hostId])
  @@index([renterId])
  @@index([roomId])
  @@index([status])
}

model ContractEvent {
  id         String          @id @default(uuid())
  contractId String
  actorId    String?
  type       String
  fromStatus ContractStatus?
  toStatus   ContractStatus?
  note       String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime        @default(now())
  actor      User?           @relation(fields: [actorId], references: [id])
  contract   Contract        @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId, createdAt])
  @@index([actorId])
}

model Occupancy {
  id                String    @id @default(uuid())
  roomId            String
  userId            String
  joinedAt          DateTime  @default(now()) @db.Timestamp(6)
  status            String    @default("ACTIVE")
  terminatedAt      DateTime?
  terminationReason String?
  notes             String?
  room              Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId], name: "Occupancy_room_user_unique")
  @@index([roomId], map: "Occupancy_roomId_idx")
  @@index([userId], map: "Occupancy_userId_idx")
  @@index([status], map: "Occupancy_status_idx")
  @@index([terminatedAt], map: "Occupancy_terminatedAt_idx")
  @@map("occupancy")
}

// Rental-owned projection of the room fields needed for capacity decisions.
// It intentionally has no relation to Room so the Rental bounded context can
// move to its own database without carrying a cross-service foreign key.
model RentalRoomSnapshot {
  roomId           String    @id
  ownerId          String?
  status           String
  maxOccupants     Int       @default(1)
  currentOccupants Int       @default(0)
  title            String?
  address          String?
  areaText         String?
  areaValue        Decimal?  @db.Decimal(10, 2)
  city             String?
  district         String?
  priceValue       BigInt?
  priceText        String?
  imageUrl         String?
  images           Json?
  amenities        Json?
  sourceUpdatedAt  DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([ownerId])
  @@index([status])
  @@map("rental_room_snapshots")
}

model RentalOutboxEvent {
  id            String    @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        String    @default("PENDING")
  attempts      Int       @default(0)
  nextAttemptAt DateTime  @default(now())
  publishedAt   DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@map("rental_outbox_events")
}

model PropertyOutboxEvent {
  id            String   @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        String   @default("PENDING")
  attempts      Int      @default(0)
  nextAttemptAt DateTime @default(now())
  publishedAt   DateTime?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@map("property_outbox_events")
}

model CommunityOutboxEvent {
  id            String   @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        String   @default("PENDING")
  attempts      Int      @default(0)
  nextAttemptAt DateTime @default(now())
  publishedAt   DateTime?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status, nextAttemptAt])
  @@index([aggregateType, aggregateId])
  @@map("community_outbox_events")
}

model IdentityInboxEvent {
  id            String   @id @default(uuid())
  eventId       String   @unique
  eventType     String
  sourceService String?
  processedAt   DateTime @default(now())

  @@index([eventType, processedAt])
  @@map("identity_inbox_events")
}

model RoomInteraction {
  id               String          @id
  userId           String
  roomId           String
  interactionType  InteractionType
  interactionValue Float           @default(1.0)
  durationSeconds  Int?            @default(0)
  createdAt        DateTime        @default(now())
  Room             Room            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  User             User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([userId])
}

model SharedResource {
  id                 String            @id @default(uuid())
  roomId             String
  name               String
  type               String
  status             String            @default("ACTIVE")
  requiresApproval   Boolean           @default(false)
  maxDurationMinutes Int               @default(120)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  description        String?
  ownerId            String
  resourceBookings   ResourceBooking[]
  room               Room              @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("shared_resources")
}

model ResourceBooking {
  id         String         @id @default(uuid())
  resourceId String
  userId     String
  title      String?
  startTime  DateTime
  endTime    DateTime
  status     String         @default("APPROVED")
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  resource   SharedResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("resource_bookings")
}

model SharedSpaceActivity {
  id         String    @id @default(uuid())
  roomId     String
  creatorId  String
  assigneeId String?
  type       String
  title      String
  content    String?
  eventDate  DateTime?
  imageUrl   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  assignee   User?     @relation("ActivityAssignee", fields: [assigneeId], references: [id])
  creator    User      @relation("ActivityCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("shared_space_activities")
}

model UtilityBill {
  id                      String    @id @default(uuid())
  contractId              String
  month                   Int
  year                    Int
  previousReading         Float?
  currentReading          Float?
  electricityUsage        Float?
  waterUsage              Float?
  electricityCost         Float?
  waterCost               Float?
  totalCost               Float
  status                  String    @default("PENDING")
  paymentProofUrl         String?
  paymentProofSubmittedAt DateTime?
  approvedAt              DateTime?
  notes                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  contract                Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, month, year])
  @@index([contractId])
  @@index([status])
  @@map("utility_bills")
}

enum SmokingType {
  NO
  OCCASIONALLY
  YES
}

enum SleepTime {
  BEFORE_10PM
  BETWEEN_10_12
  AFTER_12
}

enum GuestFrequency {
  NEVER
  SOMETIMES
  OFTEN
}

enum Role {
  CUSTOMER
  SERVER
  DELIVER
  ADMIN
  HOST
  COMMUNITY_MANAGER
}

enum ServiceRegion {
  NORTH
  CENTRAL
  SOUTH
}

enum UserStatus {
  ACTIVE
  LOCKED
  DELETED
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  PENDING
  HIDDEN
  DRAFT
  NEEDS_REVISION
  REJECTED
}

enum VerificationDocumentType {
  IDENTITY
  OWNERSHIP
  ADDRESS
  ROOM_PROOF
  OTHER
}

enum VerificationDocumentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommunityManagerRecommendation {
  PENDING
  NEEDS_REVISION
  RECOMMEND_APPROVAL
  RECOMMEND_REJECTION
}

enum VerificationCheckType {
  OWNER_PHONE
  OWNER_IDENTITY_DOCUMENT
  OWNERSHIP_DOCUMENT
  ROOM_ADDRESS
  MAP_LOCATION
  ROOM_IMAGES
  LEGAL_DECLARATION
  ROOM_DETAILS
}

enum VerificationCheckStatus {
  PENDING
  MATCHED
  MISMATCHED
  NEEDS_REVIEW
  UNVERIFIABLE
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum InvoiceStatus {
  UNSIGNED
  SIGNED
}

enum ContractStatus {
  DRAFT
  PENDING_HOST_SIGNATURE
  PENDING_RENTER_SIGNATURE
  PENDING_DEPOSIT
  PENDING_HANDOVER
  ACTIVE
  EXPIRED
  TERMINATED
  CANCELLED
  DISPUTED
}

enum ContractDepositStatus {
  NOT_REQUIRED
  PENDING
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FORFEITED
}

enum ReviewStatus {
  VISIBLE
  HIDDEN
  DELETED
}

enum InteractionType {
  VIEW
  CLICK
  FAVORITE
  BOOKING_REQ
  CONTRACT
}
